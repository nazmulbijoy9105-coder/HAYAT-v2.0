# HAYAT v2.0 — Environment Configuration
# Copy to .env and fill in production values

# Database
DATABASE_URL=postgresql+asyncpg://hayat:hayat_secret@localhost:5432/hayat_db

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hayat_neo4j_secret

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=hayat_minio
MINIO_SECRET_KEY=hayat_minio_secret
MINIO_BUCKET=hayat-documents
MINIO_SECURE=false

# OpenSearch
OPENSEARCH_HOSTS=["http://localhost:9200"]

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333

# RabbitMQ
RABBITMQ_URL=amqp://hayat:hayat_rabbit@localhost:5672/

# Security
JWT_SECRET_KEY=change-me-in-production-hayat-v2-enterprise-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o

# Application
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Bangladesh Legal Sources
BANGLADESH_CODE_API_URL=https://api.bangladeshcode.gov.bd
SUPREME_COURT_API_URL=https://api.supremecourt.gov.bd
GAZETTE_API_URL=https://api.gazette.gov.bd
